# Copia este archivo a .env y descomenta lo que necesites.

# ─── Sentry (opcional) ──────────────────────────────────────────────────────
# Si defines SENTRY_DSN se reportan errores (requiere `pip install sentry-sdk`).
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ENV=production
# SENTRY_TRACES_RATE=0.0        # 0.0 = sin tracing; 1.0 = todas las requests

# ─── Server (opcional) ──────────────────────────────────────────────────────
# DEV_RELOAD=true               # uvicorn autoreload — SOLO desarrollo, no producción
# PORT=8080
